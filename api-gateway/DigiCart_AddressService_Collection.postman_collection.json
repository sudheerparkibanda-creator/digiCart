{
  "info": {
    "name": "DigiCart Address Service",
    "description": "Address management microservice - Create, read, update, and delete customer addresses with Indian-specific location data",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Address",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"{{user_full_name}}\",\n  \"mobileNumber\": \"{{mobile_number}}\",\n  \"addressLine1\": \"{{address_line1}}\",\n  \"addressLine2\": \"{{address_line2}}\",\n  \"landmark\": \"{{landmark}}\",\n  \"city\": \"{{city}}\",\n  \"district\": \"{{district}}\",\n  \"state\": \"{{state}}\",\n  \"pinCode\": \"{{pin_code}}\",\n  \"country\": \"{{country}}\",\n  \"addressType\": \"{{address_type}}\",\n  \"alternatePhone\": \"{{alternate_phone}}\"\n}"
        },
        "url": {
          "raw": "{{address_service_url}}/addresses",
          "host": [
            "{{address_service_url}}"
          ],
          "path": [
            "addresses"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const data = pm.response.json();",
              "    if (data.addressId) {",
              "        pm.environment.set('address_id', data.addressId);",
              "        console.log('Saved address_id:', data.addressId);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get All Addresses",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{address_service_url}}/addresses",
          "host": [
            "{{address_service_url}}"
          ],
          "path": [
            "addresses"
          ]
        }
      }
    },
    {
      "name": "Get Address by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{address_service_url}}/addresses/{{address_id}}",
          "host": [
            "{{address_service_url}}"
          ],
          "path": [
            "addresses",
            "{{address_id}}"
          ]
        }
      }
    },
    {
      "name": "Update Address",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"{{user_full_name}}\",\n  \"mobileNumber\": \"9988776655\",\n  \"addressLine1\": \"Flat 10, Tower A, Prestige Meridian\",\n  \"addressLine2\": \"Koramangala, Bengaluru\",\n  \"landmark\": \"Near Bangalore International School\",\n  \"city\": \"Bengaluru\",\n  \"district\": \"Bangalore Urban\",\n  \"state\": \"KARNATAKA\",\n  \"pinCode\": \"560034\",\n  \"country\": \"India\",\n  \"addressType\": \"HOME\",\n  \"alternatePhone\": \"08025555555\"\n}"
        },
        "url": {
          "raw": "{{address_service_url}}/addresses/{{address_id}}",
          "host": [
            "{{address_service_url}}"
          ],
          "path": [
            "addresses",
            "{{address_id}}"
          ]
        }
      }
    },
    {
      "name": "Delete Address",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{address_service_url}}/addresses/{{address_id}}",
          "host": [
            "{{address_service_url}}"
          ],
          "path": [
            "addresses",
            "{{address_id}}"
          ]
        }
      }
    }
  ]
}
