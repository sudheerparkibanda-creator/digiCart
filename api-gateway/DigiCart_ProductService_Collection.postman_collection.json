{
  "info": {
    "name": "DigiCart Product Service",
    "description": "Product catalog microservice - View, create, update, and delete products. Admin operations require ADMIN role.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{product_service_url}}/products",
          "host": [
            "{{product_service_url}}"
          ],
          "path": [
            "products"
          ]
        }
      }
    },
    {
      "name": "Get Product by Code",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{product_service_url}}/products/{{product_code}}",
          "host": [
            "{{product_service_url}}"
          ],
          "path": [
            "products",
            "{{product_code}}"
          ]
        }
      }
    },
    {
      "name": "Add Product (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"LAPTOP-001\",\n  \"name\": \"Dell XPS 13\",\n  \"description\": \"Premium ultrabook with 13-inch FHD display, Intel i7, 16GB RAM\",\n  \"category\": \"Electronics\"\n}"
        },
        "url": {
          "raw": "{{product_service_url}}/products",
          "host": [
            "{{product_service_url}}"
          ],
          "path": [
            "products"
          ]
        }
      }
    },
    {
      "name": "Update Product (Admin)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"LAPTOP-001\",\n  \"name\": \"Dell XPS 13 Plus\",\n  \"description\": \"Premium ultrabook with 13-inch FHD display, Intel i7, 16GB RAM, SSD 512GB\",\n  \"category\": \"Electronics\"\n}"
        },
        "url": {
          "raw": "{{product_service_url}}/products",
          "host": [
            "{{product_service_url}}"
          ],
          "path": [
            "products"
          ]
        }
      }
    },
    {
      "name": "Delete Product (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{product_service_url}}/products/LAPTOP-001",
          "host": [
            "{{product_service_url}}"
          ],
          "path": [
            "products",
            "LAPTOP-001"
          ]
        }
      }
    }
  ]
}
