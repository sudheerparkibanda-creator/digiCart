{
  "info": {
    "name": "DigiCart Stock Service",
    "description": "Inventory management microservice - Track product stock levels. Admin operations require ADMIN role.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Stock",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{stock_service_url}}/stocks",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks"
          ]
        }
      }
    },
    {
      "name": "Get Stock by Product Code",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{stock_service_url}}/stocks/{{product_code}}",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks",
            "{{product_code}}"
          ]
        }
      }
    },
    {
      "name": "Get Stock by Multiple Product IDs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{stock_service_url}}/stocks/by-product-ids?ids=LAPTOP-001&ids=PHONE-001",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks",
            "by-product-ids"
          ],
          "query": [
            {
              "key": "ids",
              "value": "LAPTOP-001"
            },
            {
              "key": "ids",
              "value": "PHONE-001"
            }
          ]
        }
      }
    },
    {
      "name": "Add Stock (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"LAPTOP-001\",\n  \"availableQuantity\": 100\n}"
        },
        "url": {
          "raw": "{{stock_service_url}}/stocks",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks"
          ]
        }
      }
    },
    {
      "name": "Update Stock (Admin)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"LAPTOP-001\",\n  \"availableQuantity\": 85\n}"
        },
        "url": {
          "raw": "{{stock_service_url}}/stocks",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks"
          ]
        }
      }
    },
    {
      "name": "Delete Stock (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{stock_service_url}}/stocks/LAPTOP-001",
          "host": [
            "{{stock_service_url}}"
          ],
          "path": [
            "stocks",
            "LAPTOP-001"
          ]
        }
      }
    }
  ]
}
