{
  "info": {
    "name": "DigiCart Realistic Microservices Collection",
    "description": "Realistic Postman collection for DigiCart microservices with auth, address, product, cart, order, payment, and notification flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"name\": \"{{user_full_name}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{api_gateway_url}}/auth/register",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{api_gateway_url}}/auth/login",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    if (data.token) {",
                  "        pm.environment.set('token', data.token);",
                  "    }",
                  "    if (data.username) {",
                  "        pm.environment.set('username', data.username);",
                  "    }",
                  "    if (data.role) {",
                  "        pm.environment.set('user_role', data.role);",
                  "    }",
                  "    console.log('Saved token and user info.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_service_url}}/products",
              "host": [
                "{{product_service_url}}"
              ],
              "path": [
                "products"
              ]
            }
          }
        },
        {
          "name": "Get Product by Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_service_url}}/products/{{product_code}}",
              "host": [
                "{{product_service_url}}"
              ],
              "path": [
                "products",
                "{{product_code}}"
              ]
            }
          }
        },
        {
          "name": "Get Stock by Product ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{stock_service_url}}/stocks/{{product_code}}",
              "host": [
                "{{stock_service_url}}"
              ],
              "path": [
                "stocks",
                "{{product_code}}"
              ]
            }
          }
        },
        {
          "name": "Get Price by Product Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{price_service_url}}/prices/{{product_code}}",
              "host": [
                "{{price_service_url}}"
              ],
              "path": [
                "prices",
                "{{product_code}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        {
          "name": "Create Indian Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{user_full_name}}\",\n  \"mobileNumber\": \"{{mobile_number}}\",\n  \"addressLine1\": \"{{address_line1}}\",\n  \"addressLine2\": \"{{address_line2}}\",\n  \"landmark\": \"{{landmark}}\",\n  \"city\": \"{{city}}\",\n  \"district\": \"{{district}}\",\n  \"state\": \"{{state}}\",\n  \"pinCode\": \"{{pin_code}}\",\n  \"country\": \"{{country}}\",\n  \"addressType\": \"{{address_type}}\",\n  \"alternatePhone\": \"{{alternate_phone}}\"\n}"
            },
            "url": {
              "raw": "{{address_service_url}}/addresses",
              "host": [
                "{{address_service_url}}"
              ],
              "path": [
                "addresses"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    if (data.addressId) {",
                  "        pm.environment.set('address_id', data.addressId);",
                  "        console.log('Saved address_id:', data.addressId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Addresses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{address_service_url}}/addresses",
              "host": [
                "{{address_service_url}}"
              ],
              "path": [
                "addresses"
              ]
            }
          }
        },
        {
          "name": "Get Address by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{address_service_url}}/addresses/{{address_id}}",
              "host": [
                "{{address_service_url}}"
              ],
              "path": [
                "addresses",
                "{{address_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Cart & Order Flow",
      "item": [
        {
          "name": "Create Cart for Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{cart_service_url}}/{{customer_id}}/carts",
              "host": [
                "{{cart_service_url}}"
              ],
              "path": [
                "{{customer_id}}",
                "carts"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    if (data.cartId) {",
                  "        pm.environment.set('cart_id', data.cartId);",
                  "        console.log('Saved cart_id:', data.cartId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Add Product to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_code}}\",\n  \"quantity\": {{quantity}}\n}"
            },
            "url": {
              "raw": "{{cart_service_url}}/{{customer_id}}/carts/{{cart_id}}/add",
              "host": [
                "{{cart_service_url}}"
              ],
              "path": [
                "{{customer_id}}",
                "carts",
                "{{cart_id}}",
                "add"
              ]
            }
          }
        },
        {
          "name": "Set Existing Delivery Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": \"{{address_id}}\",\n  \"setAsDefaultInCustomer\": true\n}"
            },
            "url": {
              "raw": "{{cart_service_url}}/{{customer_id}}/carts/{{cart_id}}/delivery-address",
              "host": [
                "{{cart_service_url}}"
              ],
              "path": [
                "{{customer_id}}",
                "carts",
                "{{cart_id}}",
                "delivery-address"
              ]
            }
          }
        },
        {
          "name": "Place Order from Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{cart_service_url}}/{{customer_id}}/carts/{{cart_id}}/place-order",
              "host": [
                "{{cart_service_url}}"
              ],
              "path": [
                "{{customer_id}}",
                "carts",
                "{{cart_id}}",
                "place-order"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    if (data.orderId) {",
                  "        pm.environment.set('order_id', data.orderId);",
                  "        console.log('Saved order_id:', data.orderId);",
                  "    }",
                  "    if (data.paymentLink) {",
                  "        pm.environment.set('payment_link', data.paymentLink);",
                  "        console.log('Saved payment_link:', data.paymentLink);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Cart Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{cart_service_url}}/{{customer_id}}/carts",
              "host": [
                "{{cart_service_url}}"
              ],
              "path": [
                "{{customer_id}}",
                "carts"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders & Payment",
      "item": [
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{order_service_url}}/orders/{{order_id}}",
              "host": [
                "{{order_service_url}}"
              ],
              "path": [
                "orders",
                "{{order_id}}"
              ]
            }
          }
        },
        {
          "name": "Ensure Payment Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{payment_service_url}}/payments/orders/{{order_id}}/payment-link",
              "host": [
                "{{payment_service_url}}"
              ],
              "path": [
                "payments",
                "orders",
                "{{order_id}}",
                "payment-link"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    if (data.paymentLink) {",
                  "        pm.environment.set('payment_link', data.paymentLink);",
                  "        console.log('Saved payment_link:', data.paymentLink);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Capture Payment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"PAY-{{order_id}}-001\"\n}"
            },
            "url": {
              "raw": "{{order_service_url}}/orders/{{order_id}}/payment-captured",
              "host": [
                "{{order_service_url}}"
              ],
              "path": [
                "orders",
                "{{order_id}}",
                "payment-captured"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notification Tests",
      "item": [
        {
          "name": "Test Order Notification Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"userId\": \"{{customer_id}}\",\n  \"userEmail\": \"{{email}}\",\n  \"paymentLink\": \"{{payment_link}}\"\n}"
            },
            "url": {
              "raw": "{{notification_service_url}}/test/send-order-notification",
              "host": [
                "{{notification_service_url}}"
              ],
              "path": [
                "test",
                "send-order-notification"
              ]
            }
          }
        }
      ]
    }
  ]
}
