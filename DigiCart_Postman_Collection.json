              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@digicart.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "// Extract JWT token from response and set as environment variable",
                    "if (pm.response.code === 200) {",
                    "    const response = pm.response.json();",
                    "    if (response.token) {",
                    "        pm.collectionVariables.set('jwtToken', response.token);",
                    "        console.log('JWT Token saved:', response.token.substring(0, 50) + '...');",
                    "    }",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
