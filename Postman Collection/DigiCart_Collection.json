    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    if (data.token) {",
                  "        pm.environment.set('token', data.token);",
                  "    }",
                  "    if (data.username) {",
                  "        pm.environment.set('username', data.username);",
                  "    }",
                  "    if (data.role) {",
                  "        pm.environment.set('user_role', data.role);",
                  "    }",
                  "    console.log('Saved token and user info.');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
